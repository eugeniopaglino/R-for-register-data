new_names <- str_to_lower(old_names)

setnames(data,old_names,new_names)
```

Note that we could have just changed some names. In a typical workflow, the next step might be to recode the variables based on info from the NHIS documentation.

```{r}
# Code sex to factor (j syntax to create or modify variable)
data[,sex:=fifelse(sex==1,'male','female')] # This works like ifelse but it's more efficient

# Code marital status and simplify
data[
  ,
  mar_stat:=fcase(
    marstcur==0,'not asked',
    between(marstcur,1,3),'married', # Alternative syntax marstcur %in% 1:3
    marstcur==4,'separated',
    marstcur==5,'divorced',
    marstcur==6,'widowed',
    marstcur==7,'cohabiting',
    marstcur==8,'never married',
    marstcur==9,NA_character_
  )
]

# Remove original variable (efficiently because no copying occurrs)
data[,marstcur:=NULL]

# Recode race
data[
  ,
  race:=fcase(
    racenew==100,'white',
    racenew==200,'black',
    racenew==300,'AIAN',
    racenew==400,'asian',
    racenew==530,NA_character_,
    racenew==541,'multirace'
  )
]

# Remove original variable
data[,racenew:=NULL]

# Recode hispanic origin and simplify (alternative syntax)
data[,hispanic:='hispanic']
data[hispeth==10,hispanic:='non hispanic']

# Remove original variable
data[,hispeth:=NULL]

# Recode education and simplify
data[
  ,
  edu:=fcase(
    educ==0,'not asked',
    between(educ,100,116),'less than high school',
    between(educ,200,202),'high school',
    between(educ,300,303),'some college',
    educ==400,'bachelor',
    educ>400 & educ<900,'graduate',
    educ>=900,NA_character_
  )
]

# Remove original variable
data[,educ:=NULL]

# Recode BMI and simplify
data[
  ,
  bmi:=fcase(
    bmicat==1,'<18.5',
    bmicat==2,'18.5-25',
    bmicat==3,'25-30',
    bmicat==4,'>30',
    bmicat==9,NA_character_
  )
]

# Remove original variable
data[,bmicat:=NULL]

# Set correct missing values for continuous BMI
data[,bmi_c := bmicalc]
data[is.na(bmi),bmi_c:=NA_real_]

# Remove original variable (efficiently)
data[,bmicalc:=NULL]

# Recode smoking status
data[
  ,
  smoke:=fcase(
    smokestatus2==11,'every day smoker',
    smokestatus2==12,'some day smoker',
    smokestatus2==20,'former smoker',
    smokestatus2==30,'never smoker',
    smokestatus2==40,NA_character_,
    smokestatus2==90,NA_character_
  )
]

# Remove original variable (efficiently)
data[,smokestatus2:=NULL]
```

Let's take a look at our cleaned dataset.

```{r}
str(data)
```

We can see that all our categorical variables are stored as characters. This is ok but characters don't have a clear notion of ordering. When we need to define a specific order we can use a factor. We can use this to illustrate one very useful `data.table` trick

```{r}
# Select columns which we want to modify
vars_to_fct <- c('sex','mar_stat','race','hispanic','edu','bmi','smoke')
# Apply the as.factor function to all columns at the same time
data[,(vars_to_fct):=lapply(.SD,as.factor),.SDcols = vars_to_fct]
```

Check

```{r}
str(data)
```

We can now order factor variables

```{r}
data[,edu:=fct_relevel(edu,'less than high school','high school','some college','bachelor','graduate')]
# fct_relevel comes from the forcats library
# We left one level out because I don't like typing but it works because it will automatically be last
```

#### Small Digression

What is this `lapply` thingy a few code blocks above? `lapply` is part of the `apply` family of functions that are sort of compact loops for simple operations. Some examples.

```{r}
# Define a vector
a <- c('I','you','we','they')

# Add "go" to the end of each string
sapply(a,function(x) paste0(x,' go')) # Vector as output, example of anonymous function

# If we needed a list, we would do
lapply(a,function(x) paste0(x,' go'))

# Sum vector elements by group
b <- seq(1:6)
g <- rep(1:3,each=2)
tapply(b,g,sum) # Can be quite useful when working with vectors and matrices!

# If we felt posh, we could have written
sapply(unique(g),function(x) sum(b[g==x]))

# apply is the most general version but I don't find it particularly intuitive

# Define a matrix
my_mat <- matrix(
  c(c(1,2,3),
    c(4,5,6),
    c(7,8,9)),
  byrow = T,
  nrow=3,
  ncol=3
)

# Subtract row mean to each row
t(apply(my_mat,M=1,function(x) x - mean(x))) # M=1 for row-wise operations and M=2 for column-wise

# A more efficient way would be
sweep(my_mat,M=1,STATS=matrixStats::rowMeans2(my_mat),FUN="-")
# matrixStats::rowMeans2(my_mat) is the same as apply(my_mat,M=1,mean) but more efficient 
# Sweep is great but the syntax is not intuitive and I always forget what goes where
```

Combining `sapply`, `tapply`, aggregation functions for matrices from `matrixStats`, and `sweep` can get you very far and give you extremely efficient code.

#### Back to Work

We can be proud of our work. Suppose we want to take a look at prevalence of smoking by age, sex, and educational attainment. It probably makes sense to 1) group ages, 2) restrict the sample to certain ages.

```{r}
# take a quick look at the age distribution
hist(data$age) # Not pretty but quick (fancy stuff later on)
```

Say we want to create 5-year age groups and a top category for 85+ (the variable is top-coded anyway)

```{r}
data[,age_group:=cut(age,seq(0,90,5),right=F)] # Not the most straightforward syntax
data[age_group=='[85,90)',age_group:='85+']
```

We could quickly create a table of prevalence rates (i.e. proportion by smoking status) by age, sex, and education.

```{r}
# The base r way
sweep(
  table(data$age_group,data$smoke,useNA = 'always'), 
  M=1, 
  table(data$age_group,useNA = 'always'), 
  FUN = '/'
  )
# Another good use case for sweep!
```

```{r}
# The data.table way. 
freq_table <- data[,.(N=.N),by=.(age_group,smoke)] # example of grouping and aggregation
freq_table <- freq_table[,freq:=N/(sum(N)),by=.(age_group)] # example of grouping without aggregation

# Taking advantage to illustrate the syntax for a long to wide pivot
freq_table_wide <- dcast(
  freq_table,
  age_group ~ smoke,
  value.var = 'freq',
  fill = 0
)
# I forget the syntax every time even though I use this daily

freq_table_wide
```

We could revert back to long format.

```{r}
# Example of wide to long conversion
freq_table_long <- melt(
  freq_table_wide,
  id.vars = 'age_group',
  variable.name = 'smoke',
  value.name = 'freq'
)

freq_table_long
```

We could use this table for a visualization but... We'll have to wait until we get to the visualization section. 

Looking at the table, we see that the smoking questions are not asked to respondents below age 15. We can filter these individuals out and save this as a separate dataset. Because we are going to use education as a covariate, we'll also exclude people aged 29 or below because education would not be reliably measured for younger individuals.

```{r}
data_smoke <- data[age>=30] # in data.table, filtering always create a copy
```

We'll also drop the very old.

```{r}
data_smoke <- data_smoke[age<85] # in data.table, filtering always create a copy
data_smoke <- data_smoke[!is.na(edu)] # Drop observations with missing education
```

### Some Statistical Modeling

Back to our question of whether smoking prevalence varies by educational status, we could start by operationalizing our outcome as being currently a smoker.

```{r}
data_smoke[,current_smoker:=0]
data_smoke[smoke %chin% c('every day smoker','some day smoker'),current_smoker:=1]
# %chin% is a more efficient version of %in% specialized for characters
```

The simplest model we can run is a linear probability model. We can do that easily:

```{r}
lm_fit <- lm(current_smoker ~ 1 + edu + age_group + sex,data=data_smoke)
summary(lm_fit)
```

Not the nicest output maybe. We can do better.

```{r}
# This is your friend to summarize models. Highly customizable and outputs a 
# data.frame so can be easily manipulated further
broom::tidy(lm_fit)
```

We could have also used a logistic model, so a generalized linear model.

```{r}
glm_fit <- glm(current_smoker ~ 1 + edu + age_group + sex,data=data_smoke,family = 'binomial')

# Can be used to fit other GLMs
# poisson, gamma, quansi poisson, see MASS::glm.nb for negative-binomial

summary(glm_fit)
```

We could have decided that dummy variables for age are annoying (they certainly are) and opted for a GAM.

```{r}
library(mgcv)
gam_fit <- gam(current_smoker ~ 1 + edu + s(age,k=20) + sex,data=data_smoke)
summary(gam_fit)
```

```{r}
# Secret trick
plot(gam_fit) # To quickly visualize the smooth terms
```

Just for fun, we could decide to fit a model with random intercepts for age (not a great idea but good show the syntax)

```{r}
library(lme4)
mlm_fit <- lmer(current_smoker ~ 1 + edu + sex + (1 | age_group),data=data_smoke)
summary(mlm_fit)
```

### Working with Models

Back to our basic linear model, R gives use some useful functions to manipulate the model object.

```{r}
# Simplify model to keep things simple
lm_fit <- lm(current_smoker ~ 1 + edu + age + sex + edu:sex,data=data_smoke)
# Extract coefficients
coef(lm_fit)
```

```{r}
# Extract variance-covariance matrix
vcov(lm_fit)
```

```{r}
# Predict
predict(lm_fit)[1:5]
# To predict on new data use predict(lm_fit,newdata=new_data)
```

```{r}
# Get residuals
residuals(lm_fit)[1:5]
```

Want to do some fancy simulations? Easy-peasy

```{r}
# Get model matrix
X <- model.matrix(lm_fit,data=data_smoke)
# Get simulated coefficients from multivariate Normal
beta <- MASS::mvrnorm(1000,coef(lm_fit),vcov(lm_fit))
y <- beta %*% t(X) # Matrix algebra is great!

# Get means, medians, percentiles efficiently
library(matrixStats) # This is your friend for fast matrix manipulation
y_mean <- colMeans2(y)
y_median <- colMedians(y)
y_q <- colQuantiles(y,probs = c(0.025,0.975))

# Assemble into a data.table
y_summary <- data.table(
  y_real = data_smoke$current_smoker,
  y_mean = y_mean,
  y_median = y_median,
  y_025 = y_q[,1],
  y_975 = y_q[,2]
)

y_summary[1:5]
```

I use this basic workflow a lot to get confidence intervals for complex quantities. We could also compute the average proportion of current smokers by sex and education level.

```{r}
# Create new data
new_data <- expand.grid(
  current_smoker=1,
  age=30:84,
  sex=unique(data_smoke$sex),
  edu=unique(data_smoke$edu)
)
# Great function to create a data.frame from combinations of column values

# Make it a data.table
setDT(new_data)

# Get model matrix
X <- model.matrix(lm_fit,data=new_data) # Also useful to understand model structure
# Get simulated coefficients from multivariate Normal
beta <- MASS::mvrnorm(1000,coef(lm_fit),vcov(lm_fit))
y <- beta %*% t(X)

# Define groups
new_data[,group:=.GRP,by=.(sex,edu)]

# Average over age to get marginal effect
y <- sapply(unique(new_data$group), function(g) {
  rowMeans2(y[,new_data$group==g])
})
# Yes, this is a more complex version of our tapply using sapply example

# Get means, medians, percentiles efficiently
y_mean <- colMeans2(y)
y_median <- colMedians(y)
y_q <- colQuantiles(y,probs = c(0.025,0.975))

# Assemble into a data.table
y_summary <- data.table(
  y_real = data_smoke[,.(prop=mean(current_smoker)),by=.(sex,edu)],
  y_mean = y_mean,
  y_median = y_median,
  y_025 = y_q[,1],
  y_975 = y_q[,2]
)

y_summary
```

We can easily visualize all of our hard work.

```{r,fig.width=10}
# Bit of a spoiler
y_summary |>
  ggplot() +
  geom_point(mapping=aes(x=y_real.edu,y=y_mean)) +
  geom_linerange(mapping=aes(x=y_real.edu,ymin=y_025,ymax=y_975)) +
  facet_wrap(~y_real.sex) +
  labs(x='Education',y='Proportion of current smokers') +
  theme_bw()
```

Ok, this was nice! 

We covered some frequently used statistical methods but there are many specialized statistical packages for other methods:

  - `feols` for efficient fixed-effects estimation (economists I am looking at you!)
  - `rstan` and `brms`, R interfaces to Bayesian inference with Stan 
  - `rjags`, R interfaces to Bayesian inference with JAGS 
  - `INLA`, approximate Bayesian inference
  - `survival` survival models (and many utilities for survival data)
  - `MASS` lots of utility functions and more statistical models (e.g. ordered logistic regression, negative binomial models)
  - `nnet` (hint: you need three of these and a trenchcoat to create a multistate model)
  - `censReg` censored regression models (tobit)
  - `forecast` ARIMA and friends
  - `DemoTools` everything demography (`DemoDecomp` for demographic decomposition methods)
  - `sampleSelection` Heckman selection models
  
The R package environment can be confusing and there is a non trivial degree of duplication (multiple packages doing the same thing, likely with a different syntax). At the same time, R is the language of choice for the statistical community (excluding ML and economists) so the breadth of models you can fit with R is very impressive.

### Dealing with Multiple Models

Often, you'll need to run multiple models on the same dataset. For example, we might want to run separate models for sex and race combinations. Here is one way of doing it

```{r}
# Create group indicator
data_smoke[,group:=.GRP,by=.(sex,race)] # .GRP is data.table lingo, there is also .N for group size
models <- vector(mode='list',length = max(data_smoke$group))

for (i in 1:length(models)) {
  this_lm_fit <- lm(current_smoker ~ 1 + edu + age,data=data_smoke[group==i])
  models[[i]] <- this_lm_fit
}
```

We could then have another loop to do something with our models. Say we want to store the predicted proportions for each individual, we could do

```{r}
# Create group indicator
data_smoke[,group:=.GRP,by=.(sex,race)]
# Create dictionary of groups
group_dict <- unique(data_smoke[,.(group,sex,race)]) # R is smart and dispatches unique to unique.data.table
# Set up data structure
predict_data <- vector(mode='list',length = max(data_smoke$group))

for (i in 1:length(models)) {
  this_lm_fit <- lm(current_smoker ~ 1 + edu + age,data=data_smoke[group==i])
  this_predict_data <- data.table(y_pred=predict(this_lm_fit))
  
  # Add group to keep track
  this_predict_data[,group:=i]
  
  # Add to list
  predict_data[[i]] <- this_predict_data
}

# Create single data.table
predict_data <- rbindlist(predict_data)
# Bring back group variables
predict_data <- merge(predict_data,group_dict,by='group')
```

You can make this more complicated, potentially wrapping the code inside the for loop into one or multiple functions, but the basic structure is the same.

### Combining Datasets

One more thing worth illustrating is how to combine datasets (merge). Let's go back to our full data and suppose we want to standardize continuous BMI values so they have mean zero and a standard deviation of one. We want to do this separately by sex because the distribution might be different.

The fastest way of doing this would be:

```{r}
# Get rid of respondents for which BMI is missing
data_bmi <- data[!is.na(bmi_c)]

# Compute mean and standard deviation of BMI
data_bmi[,bmi_mean:=mean(bmi_c),by=.(sex)]
data_bmi[,bmi_sd:=sd(bmi_c),by=.(sex)]

# We can then create our standardized BMI scores
data_bmi[,bmi_std:=(bmi_c-bmi_mean)/bmi_sd]

# Let's check that everything is right
mean(data_bmi$bmi_std)
sd(data_bmi$bmi_std)
```

But, if for some reason we first want to compute the sex-specific means and standard deviations, we could do so and the merge the resulting data.table onto our data:

```{r}
# Get rid of respondents for which BMI is missing
data_bmi <- data[!is.na(bmi_c)]

# Compute mean and standard deviation of BMI
data_bmi_summary <- data_bmi[,.(bmi_mean=mean(bmi_c),bmi_sd=sd(bmi_c)),by=.(sex)]
# Example of aggregation with by

# Merge
data_bmi <- merge(data_bmi,data_bmi_summary,by=c('sex'))

# We can then create our standardized BMI scores
data_bmi[,bmi_std:=(bmi_c-bmi_mean)/bmi_sd]

# Let's check that everything is right
mean(data_bmi$bmi_std)
sd(data_bmi$bmi_std)
```

The result is the same. The operation we just performed is also known as joining. There are four types which `data.table` conveniently handles with just one function:

  - Inner join: keeps only entries found in both databases. This is the default option.
  - Left join: keeps only entries found in left database. Specify option `all.x=T`.
  - Right join: keeps only entries found in left database. Specify option `all.y=T`.
  - Outer join: keeps any entry found in one of the two databases. Specify option `all=T`.

Also, the two data.table might have different names for the same variables. It is possible to specify different merging variables in the first (x) and second (y) table with options `by.x` and `by.y`. However, I think having consistent names across tables is advisable.

### Building Visualization with `ggplot2`

`ggplot2` is a general purpose library for visualizing data. The key principle of `ggplot2` is the idea of building up a plot by combining different layers, each responsible for a specific function. You can learn more about `ggplot2` philosophy [here](http://vita.had.co.nz/papers/layered-grammar.pdf) but it's probably best to start with an example. We will be using the following classic dataset:

```{r}
head(iris) # Returns the first 5 elements
```

We wish to plot sepal length against sepal width.

```{r}
ggplot(data=iris)+ # Notice that we use + and not the pipe |>
  geom_point(mapping=aes(x=Sepal.Length,y=Sepal.Width))
```

We specify that the data we want to use is in the `iris` object. Then we add our first layer `geom_point` and tell `ggplot2` that `Sepal.Length` should be mapped to the x-axis and `Sepal.Width` should be mapped to the y-axis.

Congratulations! This is your first graph. Suppose we want to change point shape based on the species.

```{r}
ggplot(data=iris) + # Notice that we use + and not the pipe %>%
  geom_point(
    mapping=aes(
      x=Sepal.Length,
      y=Sepal.Width,
      shape=Species)
    )
```

We just need to map the `Species` variable to the shape aesthetic.

If we felt that the shape alone is not enough to help the viewer separate points by species, we could add color:

```{r}
plot <- ggplot(
  data=iris,
  mapping=aes(x=Sepal.Length,y=Sepal.Width) 
  ) +
  geom_point(mapping=aes(shape=Species,color=Species)) 

plot
```

Note that whatever we set in the first call to `ggplot` (i.e. before any other layers are added), gets inherited by all subsequent layers. However, we can always overwrite it if, for example, we want to use a different dataset just for a specific layer (though things get tricky).

Suppose we want to focus on a specific portion of the graph:

```{r}
plot +
  coord_cartesian(xlim=c(6,7),ylim=c(2.5,3.5))
```

`coord_cartesian` controls the coordinates and can zoom on a part of the plot. Notice that we have stored our previous plot into the `plot` object and we are now adding more layers to it with the `+` operator. It's sort of an algebra of graphics.

We can change the axis labels and add a title:

```{r}
plot +
  labs(x='Sepal Length',
       y='Sepal Width',
       title='The Relationship of Sepal Width and Lenght')
```

We could also add a regression line:

```{r} 
plot +
  geom_smooth(method = 'lm', se = F,color='gray') 
```

Maybe it would be better to have each species in a separate graph:

```{r, fig.width=7}
plot +
  facet_wrap(~Species)
```

`facet_grid` allows to specify which variables should be used in the rows and which in the columns.

We are not confined to points. Here is a histogram of sepal length.

```{r}
ggplot(iris) +
  geom_histogram(mapping=aes(x=Sepal.Length),
                 bins = 10,color='black',fill='white')
```

There are many different geometries you can use:

- Lines: `geom_line`
- Boxplots: `geom_boxplot`
- Densities: `geom_density`
- Maps: `geom_map`
- Error Bars: `geom_errorbar`
- Uncertainty Intervals: `geom_ribbon`

and many more.

You can customize almost every aspect of a plot: axes, labels, grid lines, legend, orientation, size, palettes. However, `ggplot2` also offers a set of themes that modify several aspects of a figure at once:

```{r} 
plot +
  theme_minimal()
```

```{r} 
plot +
  theme_bw()
```

```{r} 
plot +
  theme_classic()
```

and more are available through the `ggthemes` package. You can combine different geometries and other elements to build very complex visualizations. Here are two examples from my own research. For example, we could combine two different plots and some panel tags.

```{r,fig.width=6}
# Create plot of sepal length over width
plot1 <- iris |>
  ggplot() +
  geom_point(mapping=aes(x=Sepal.Width,y=Sepal.Length)) +
  geom_smooth(mapping=aes(x=Sepal.Width,y=Sepal.Length)) +
  labs(x='Sepal width',y='Sepal length') +
  theme_minimal()

plot1

# Create plot of petal length over width
plot2 <- iris |>
  ggplot() +
  geom_point(mapping=aes(x=Petal.Width,y=Petal.Length)) +
  geom_smooth(mapping=aes(x=Petal.Width,y=Petal.Length)) +
  labs(x='Petal width',y='Petal length') +
  theme_minimal()

plot2

# Combine
library(patchwork)
plot1 + plot2 + plot_annotation(tag_levels = 'A')
```

We can save plots through `R`'s graphic devices. I am a fan of svg, but there are many formats. The basic syntax is:

```{r}
svg(here('outputs','figures','my_first_plot.svg'),width = 8,height = 4)
plot1 + plot2 + plot_annotation(tag_levels = 'A')
dev.off()
```

I would not recommend non-vector formats (e.g. png or jpeg), because it's hard to get them in the desired definition (at least I find it hard).

