There are more packages for specialized graphs. Some examples:

  - `ggh4x` extensions to `ggplot`, particularly useful for fancy faceting
  - `geofacet` geofaceting
  - `colorspace` colors
  - `ggsci` those beautiful color palettes from big journals

### Amazing Tables with `gt`

R is great for automating table creation. We can use our frequency table in `freq_table_wide` to illustrate what we can do.

```{r}
library(gt)

# Fix column order
setcolorder(
  freq_table_wide,
  c('age_group','every day smoker','some day smoker',
    'former smoker','never smoker','NA')
  )

# We can make the proportions into percentage so they look prettier
vars_to_multiply <- c(
  'every day smoker','some day smoker',
  'former smoker','never smoker','NA'
  )

freq_table_wide[,(vars_to_multiply):=lapply(.SD,function(x) x*100),.SDcols = vars_to_multiply]

freq_table_wide |>
  gt() |>
  cols_label(
    age_group='Age',
    `every day smoker`='Every day smoker',
    `some day smoker`='Some day smoker',
    `former smoker`='Former smoker',
    `never smoker`='Never smoker',
    `NA`='Missing'
  ) |>
  fmt_number(
    `every day smoker`:`NA`,
    decimals = 2
  )
```

Now another example with our predictions in `y_summary`, to show some additional functionalities.

```{r}
# Drop median and observed proportion and give better names
y_summary[,c('y_real.prop','y_median'):=NULL]
setnames(y_summary,c('y_real.sex','y_real.edu'),c('sex','edu'))

# I don't like typing so simplify sex
y_summary[,sex:=fifelse(sex=='female','f','m')]

# We can make the proportions into percentage so they look prettier
vars_to_multiply <- c('y_mean','y_025','y_975')

y_summary[,(vars_to_multiply):=lapply(.SD,function(x) x*100),.SDcols = vars_to_multiply]

# First reshape to wide
y_summary_table <- dcast(
  y_summary,
  edu ~ sex,
  value.var = c('y_mean','y_025','y_975')
)

# Set column order
setcolorder(y_summary_table,c('edu','y_mean_f','y_025_f','y_975_f'))

# Create table
y_summary_table |>
  gt() |>
  cols_label(
    edu='Educational attainment',
    y_mean_f='Mean',
    y_025_f='2.5th pct',
    y_975_f='97.5th pct',
    y_mean_m='Mean',
    y_025_m='2.5th pct',
    y_975_m='97.5th pct'
  ) |>
  fmt_number(
    y_mean_f:y_975_m,
    decimals = 2
  ) |>
  tab_spanner(
    y_mean_f:y_975_f,
    label='Female'
  ) |>
  tab_spanner(
    y_mean_m:y_975_m,
    label='Male'
  )
```

We could have made something simpler by first creating a pretty formatted column

```{r}
# Create summary column and remove the rest
# Create utility function to round and pad
# (Yes this might have gotten a bit out of hand)
round_and_pad <- function(x,decimals=2) {
  rounded_x <- as.character(round(x,decimals))
  
  # Split integer and decimal part
  integer_part <- str_match(rounded_x,'^\\d+') # Regular expressions!
  
  # Is there a decimal part?
  decimal_part <- fifelse(
    str_detect(rounded_x,'\\.'),
    str_match(rounded_x,'\\d+$'),
    paste0(rep('0',decimals),collapse='')
    )
  # Is this a vectorized if else statement? Yes it is!
  
  # Pad integer part
  integer_part <- str_pad(integer_part,width = 2, pad=' ',side='left')
  
  # Pad decimal part
  decimal_part <- str_pad(decimal_part,width = 2, pad='0',side='right')
  
  clean_x <- paste0(integer_part,'.',decimal_part)
  clean_x
}

y_summary[,y_sum:=paste0(
  round_and_pad(y_mean,2),
  ' (',
  round_and_pad(y_025,2),
  ', ',
  round_and_pad(y_975,2),
  ')'
  )]

# First reshape to wide
y_summary_table <- dcast(
  y_summary,
  edu ~ sex,
  value.var = c('y_sum')
)

# Create table
y_summary_table |>
  gt() |>
  cols_label(
    edu='Educational attainment',
    f='Female',
    m='Male'
  ) |>
  tab_spanner(
    f:m,
    label='Mean (2.5 pct, 97.5 pct)'
  )
```

To save, we can do

```{r}
